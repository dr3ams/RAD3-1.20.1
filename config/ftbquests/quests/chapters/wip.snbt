		}
		{
			dependencies: ["779D392E48E20A04"]
			description: [
				"You find the buried treasure chest on a nearby shore."
				""
				"Inside, nestled among gold coins and a tattered logbook, gleams the &6Heart of the Sea&r."
				""
				"&o&8The logbook entry reads: &3&o\"To whoever finds this — do not trust the guild. They sink their own ships to collect the insurance and silence the crews. The chest holds the proof. Use it.\"&r&r"
				""
				"The captain's last act was not revenge. It was justice."
			]
			hide_until_deps_complete: true
			hide_until_deps_visible: true
			icon: "minecraft:heart_of_the_sea"
			id: "678EBDCA589C3DA7"
			rewards: [
				{
					id: "58E0AC0AADF73FDE"
					type: "xp"
					xp: 80
				}
				{
					id: "128DC27E5C63F1C4"
					item: {
						Count: 1
						id: "ftbquests:lootcrate"
						tag: {
							type: "dungeon_coin_reward"
						}
					}
					type: "item"
				}
				{
					id: "7366691A310DC00E"
					item: "minecraft:conduit"
					type: "item"
				}
			]
			tasks: [
				{
					id: "5158461187AFEE8E"
