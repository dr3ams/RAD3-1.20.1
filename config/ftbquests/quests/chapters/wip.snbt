			x: 36.0d
			y: -14.5d
		}
		{
			dependencies: ["0A2B64BF18182507"]
			description: [
				"The chest isn't worth dying over. You've already come further than most."
				""
				"You slip away through a side passage, leaving &4Salazar&r to wrestle with the lock."
				""
				"&o&8As you surface, you hear a distant rumble from below the sea floor. Whether Salazar found what he was looking for — or whether the monument found him — you'll never know.&r&r"
			]
			hide_until_deps_complete: true
			hide_until_deps_visible: true
			id: "61ED745BDFE19A4C"
			incompatible: ["779D392E48E20A04"]
