			y: -6.0d
		}
		{
			dependencies: ["5C6AC4DE0A725B7E"]
			description: [
				"&6&lThe Amber Throne.&r"
				""
				"It is enormous. Carved from a single piece of amber the size of a house, its surface cracked with age but still pulsing with a dim inner light."
				""
				"&4Seated upon it — or rather, fused with it — is a figure that was once human. The ancient king.&r"
				""
				"&o&8He did not die on his throne. He became it. The amber preserves him, but the preservation has become something else — a prison, and a power source for whatever has been restlessly stirring beneath this desert for centuries.&r&r"
				""
				"&4The king opens his eyes."
				""
				"\"&6&oYou carry the seal-tablet. You broke the seal. You&r&4&o are responsible.&r&r\""
			]
			hide_until_deps_complete: true
			hide_until_deps_visible: true
			id: "0E3ED5CB4D7FDB47"
			rewards: [{
				id: "2E5BE6F9DC76CD20"
				type: "xp"
				xp: 30
			}]
			subtitle: "&4Incompatible with \"Shatter the Throne\"&r"
			tasks: [{
				id: "2120BAB9769153F1"
				type: "checkmark"
			}]
			title: "Bind the Throne — Restore the Seal"
			x: 36.0d
			y: -7.0d
		}
		{
			dependencies: ["5C6AC4DE0A725B7E"]
			description: [
				"&6&lThe Amber Throne.&r"
				""
				"It is enormous. Carved from a single piece of amber the size of a house, its surface cracked with age but still pulsing with a dim inner light."
				""
				"&4Seated upon it — or rather, fused with it — is a figure that was once human. The ancient king.&r"
				""
				"&o&8Power radiates from the throne in waves. You could feel it from across the room. Whatever is stored inside this thing — centuries of offering, sacrifice, worship — it could be yours.&r&r"
				""
				"The only thing between you and it is whatever remains of the king."
			]
			hide_until_deps_complete: true
			hide_until_deps_visible: true
			id: "304845FA014A17D8"
			rewards: [{
				id: "274DC22FFA924AD8"
				type: "xp"
				xp: 30
			}]
			subtitle: "&4Incompatible with \"Bind the Throne — Restore the Seal\"&r"
			tasks: [{
				id: "24EF0567C563784A"
				type: "checkmark"
			}]
			title: "Shatter the Throne"
			x: 36.0d
			y: -5.0d
		}
		{
			dependencies: ["0E3ED5CB4D7FDB47"]
			description: [
				"The king tells you the truth of it:"
				""
				"&6&o\"The seal was placed by my own hand, centuries ago. I chose this. The throne is not a prison — it is a lock. What it contains must never be free.\"&r&r"
				""
				"&o&8To restore the seal you must bring what was used to forge it the first time: a fragment of enchanted obsidian, a diamond at its heart, and three golden seals — offerings once given by the king's court.&r&r"
				""
				"\"&6&oDo this, and the desert will sleep again. You have my word — and my word has held for four hundred years.\"&r&r"
			]
			hide_until_deps_complete: true
			hide_until_deps_visible: true
