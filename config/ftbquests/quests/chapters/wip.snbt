						}
					}
				}
				type: "item"
			}]
			x: 32.0d
			y: 3.0d
		}
		{
			id: "2CA13E243B6520CD"
			rewards: [{
				command: "/give @a simplyswords:iron_cutlass{display:{Name:'[{\"text\":\"Custom Name\",\"italic\":false}]',Lore:['[{\"text\":\"Custom lore can be any text but probably not too long\",\"italic\":false}]']},Enchantments:[{lvl:2,id:knockback},{lvl:3,id:looting},{lvl:5,id:smite}],AttributeModifiers:[{AttributeName:\"generic.max_health\",Amount:6,Slot:mainhand,UUID:[I;-126222,14876,71257,-29752],Name:1774156542617}]}"
