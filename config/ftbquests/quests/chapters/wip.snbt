				{
					entity: "minecraft:guardian"
					id: "196DC9D71887248E"
					type: "kill"
					value: 10L
				}
			]
			title: "Into the Monument"
			x: 34.5d
			y: -13.5d
		}
		{
			dependencies: ["0A2B64BF18182507"]
			description: [
				"The lock requires a &6Heart of the Sea&r — something the captain must have hidden separately as insurance."
				""
				"&4Salazar knows this too. You can hear him somewhere deeper in the monument, cursing."
				""
				"&3&o\"The old snake. He split the key from the lock on purpose. Half in the sea, half in the earth. You'll need to find a buried treasure to open it.\"&r&r"
			]
			hide_until_deps_complete: true
			hide_until_deps_visible: true
			id: "779D392E48E20A04"
			incompatible: ["61ED745BDFE19A4C"]
