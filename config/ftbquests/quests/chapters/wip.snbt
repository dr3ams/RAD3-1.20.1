					type: "structure"
				}
				{
					consume_items: true
					id: "2165F6B8530876E8"
					item: "minecraft:heart_of_the_sea"
					type: "item"
				}
			]
			title: "The Captain's Legacy"
			x: 37.5d
			y: -14.5d
		}
		{
			description: [
				"You find a dead crow on your path, pinned to a tree with a silver needle."
				""
				"A small note tied to its leg reads:"
				""
				"&5&o\"The pact is broken. Come to the &2Hawthorn Circle&r&5&o before the next full moon, or the curse spreads. You know what you did.\"&r&r"
				""
				"&o&8You don't remember making any pact. But you notice, with some unease, that you can no longer smell anything. The curse has already begun.&r&r"
			]
			icon: "minecraft:feather"
			id: "3AF6284A78CE01BC"
			rewards: [{
				id: "62CF86AC95EB8571"
				type: "xp"
				xp: 15
			}]
			tasks: [{
				biome: "minecraft:dark_forest"
				id: "7390FE247793514A"
				title: "Enter the Dark Forest"
				type: "biome"
			}]
			title: "The Crow's Warning"
			x: 30.0d
			y: -11.0d
		}
		{
			dependencies: ["3AF6284A78CE01BC"]
			description: [
				"Deeper in the dark forest, the trees begin to thin into a perfect clearing."
				""
				"&2Twisted hawthorn branches&r form an arch overhead, and beneath them stands a ring of mossy stones, each carved with a different symbol. At the center, a cold fire pit still smells faintly of &5burned herbs&r."
				""
				"&o&8Someone was here recently. The ash is still warm. Whoever set this pact came here, performed a ritual, and left in a hurry. The symbols on the stones are in a language you don't recognise — but one word repeats on each stone: a name. Your name.&r&r"
				""
				"&4How is that possible?"
			]
			hide_until_deps_complete: true
			hide_until_deps_visible: true
			icon: {
				Count: 1
				id: "ftbquests:custom_icon"
				tag: {
					Icon: "minecraft:textures/block/mossy_stone_bricks.png"
				}
			}
			id: "011832728CF1D69F"
			rewards: [{
				id: "5DEB8B1FA872355A"
				type: "xp"
				xp: 20
			}]
			tasks: [
				{
					id: "66C89DDBD6A5E836"
					structure: "when_dungeons_arise:witch_hut"
					title: "Find the Hawthorn Circle"
					type: "structure"
				}
				{
					id: "4F4730E9F84C1E68"
					observe_type: 0
					timer: 0L
					title: "Inspect the ritual stones"
					to_observe: "minecraft:brewing_stand"
					type: "observation"
				}
			]
			title: "The Hawthorn Circle"
			x: 31.5d
			y: -11.0d
		}
		{
			dependencies: ["011832728CF1D69F"]
			description: [
				"A twig snaps behind you."
				""
				"You turn to find a woman watching you from the tree line — old, sharp-eyed, wrapped in layers of dried herbs and dark cloth. She doesn't look surprised to see you."
				""
				"&5&o\"So the curse found its mark. Good. That means the ritual worked — at least in part.\"&r&r"
				""
				"&o&8She introduces herself as &5Maren&r&o&8, a hedge-witch who has been tracking a corrupted nature spirit for months. She needed an &2anchor&r for her binding ritual — a living person whose name the forest could attach itself to. She chose you, a stranger passing through.&r&r"
				""
				"\"I apologise for the inconvenience,\" she says, not apologetically at all."
				""
				"\"Help me finish the ritual and the curse lifts. Refuse and... it won't.\""
			]
			hide_until_deps_complete: true
			hide_until_deps_visible: true
			icon: "simplehats:zigzagwitchhat"
			id: "5300718DDDE89FD4"
			rewards: [{
				id: "2FEF654072C86F56"
				type: "xp"
				xp: 10
			}]
			tasks: [{
				id: "3E71DBFD57FF9677"
