		{
			dependencies: ["304845FA014A17D8"]
			description: [
				"&4The king fights you.&r"
				""
				"&o&8He is slow — four centuries of immobility will do that — but he is &bimmensely strong&r. And the throne feeds him. Every time you push him back, the amber light flares and his wounds close.&r&r"
				""
				"You realise quickly: you cannot kill him while he touches the throne."
				""
				"&4You must break the throne first. Then him."
			]
			hide_until_deps_complete: true
			hide_until_deps_visible: true
